{
  "name": "flaketrack",
  "version": "0.1.1",
  "private": true,
  "description": "Zero-backend flaky-test detection, trending, and quarantine for GitHub Actions. Runs entirely inside your repo.",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.ts --source-map --license licenses.txt",
    "build:dashboard": "ncc build src/dashboard/cli.ts -o dist/dashboard --source-map",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --max-warnings 0",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "all": "npm run typecheck && npm run lint && npm run test && npm run build && npm run build:dashboard"
  },
  "license": "MIT",
  "dependencies": {
    "@actions/core": "3.0.1",
    "@actions/github": "9.1.1",
    "fast-xml-parser": "5.10.1",
    "glob": "^13.0.6"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vercel/ncc": "^0.38.3",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.65.0",
    "vitest": "4.1.10"
  },
  "engines": {
    "node": ">=20"
  }
}
